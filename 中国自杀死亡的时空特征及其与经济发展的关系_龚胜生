<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>中国自杀死亡的时空特征研究 | 学术可视化</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;700&family=Noto+Serif+SC:wght@400;600;700&family=IBM+Plex+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #f8f6f1;
  --surface: #ffffff;
  --ink: #1c1c1e;
  --ink-soft: #48484a;
  --ink-muted: #8e8e93;
  --teal: #2d6a6a;
  --teal-light: #e8f3f3;
  --amber: #b45309;
  --amber-light: #fef3c7;
  --rose: #9f1239;
  --rose-light: #fff1f2;
  --border: #e5e1d8;
  --shadow: 0 1px 4px rgba(0,0,0,0.08), 0 4px 16px rgba(0,0,0,0.04);
}

* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }

body {
  font-family: 'Noto Sans SC', sans-serif;
  background: var(--bg);
  color: var(--ink);
  font-size: 15px;
  line-height: 1.7;
}

/* ── CRISIS BANNER ── */
.crisis-banner {
  background: var(--teal);
  color: #fff;
  text-align: center;
  padding: 0.65rem 1.5rem;
  font-size: 0.8rem;
  letter-spacing: 0.02em;
  position: sticky;
  top: 0;
  z-index: 200;
}
.crisis-banner a { color: #a7f3d0; text-decoration: none; font-weight: 500; }
.crisis-banner a:hover { text-decoration: underline; }

/* ── NAV ── */
nav {
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  padding: 0 3rem;
  display: flex;
  align-items: center;
  gap: 2rem;
  position: sticky;
  top: 2.2rem;
  z-index: 100;
  box-shadow: 0 1px 6px rgba(0,0,0,0.06);
  overflow-x: auto;
}
.nav-logo {
  font-family: 'Noto Serif SC', serif;
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--teal);
  white-space: nowrap;
  padding: 1rem 0;
  margin-right: 1rem;
}
nav a {
  font-size: 0.78rem;
  color: var(--ink-muted);
  text-decoration: none;
  white-space: nowrap;
  padding: 1rem 0;
  border-bottom: 2px solid transparent;
  transition: all 0.2s;
}
nav a:hover { color: var(--teal); border-bottom-color: var(--teal); }

/* ── HERO ── */
.hero {
  padding: 5rem 3rem 4rem;
  max-width: 960px;
  margin: 0 auto;
}
.hero-kicker {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.68rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--teal);
  margin-bottom: 1.2rem;
}
.hero h1 {
  font-family: 'Noto Serif SC', serif;
  font-size: clamp(1.8rem, 3.5vw, 2.8rem);
  line-height: 1.3;
  font-weight: 700;
  color: var(--ink);
  margin-bottom: 1.5rem;
  max-width: 720px;
}
.hero-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem 2rem;
  font-size: 0.82rem;
  color: var(--ink-muted);
  margin-bottom: 2rem;
}
.hero-meta span { display: flex; align-items: center; gap: 0.4rem; }
.hero-abstract {
  background: var(--surface);
  border-left: 3px solid var(--teal);
  padding: 1.5rem 2rem;
  border-radius: 0 6px 6px 0;
  font-size: 0.9rem;
  color: var(--ink-soft);
  line-height: 1.85;
  max-width: 760px;
  box-shadow: var(--shadow);
}

/* ── SECTION ── */
section { padding: 4rem 3rem; max-width: 960px; margin: 0 auto; }
section + section { padding-top: 0; }

.section-label {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.65rem;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--teal);
  margin-bottom: 0.6rem;
}
.section-title {
  font-family: 'Noto Serif SC', serif;
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--ink);
  margin-bottom: 1.8rem;
}
.section-body {
  font-size: 0.9rem;
  color: var(--ink-soft);
  line-height: 1.9;
  max-width: 700px;
  margin-bottom: 2rem;
}

/* ── DIVIDER ── */
.divider {
  border: none;
  border-top: 1px solid var(--border);
  margin: 0 3rem;
}

/* ── STATS STRIP ── */
.stats-strip {
  background: var(--teal);
  color: #fff;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  padding: 2.5rem 3rem;
}
.stat-item { text-align: center; padding: 0 1rem; }
.stat-item + .stat-item { border-left: 1px solid rgba(255,255,255,0.2); }
.stat-num {
  font-family: 'Noto Serif SC', serif;
  font-size: 2.2rem;
  font-weight: 700;
  line-height: 1.1;
  margin-bottom: 0.4rem;
}
.stat-label {
  font-size: 0.75rem;
  opacity: 0.8;
  line-height: 1.4;
}

/* ── TIMELINE TABS ── */
.tab-bar {
  display: flex;
  gap: 0;
  border-bottom: 2px solid var(--border);
  margin-bottom: 2rem;
  flex-wrap: wrap;
}
.tab-btn {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.72rem;
  letter-spacing: 0.08em;
  padding: 0.7rem 1.4rem;
  border: none;
  background: transparent;
  cursor: pointer;
  color: var(--ink-muted);
  border-bottom: 2px solid transparent;
  margin-bottom: -2px;
  transition: all 0.2s;
}
.tab-btn.active { color: var(--teal); border-bottom-color: var(--teal); font-weight: 500; }
.tab-btn:hover:not(.active) { color: var(--ink); }

.tab-panel { display: none; animation: fadeIn 0.3s; }
.tab-panel.active { display: block; }

@keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }

/* ── CHART BARS ── */
.bar-chart {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}
.bar-row {
  display: grid;
  grid-template-columns: 80px 1fr 60px;
  align-items: center;
  gap: 0.8rem;
  font-size: 0.8rem;
}
.bar-row label { color: var(--ink-soft); text-align: right; font-size: 0.78rem; }
.bar-track {
  height: 20px;
  background: var(--teal-light);
  border-radius: 3px;
  overflow: hidden;
}
.bar-fill {
  height: 100%;
  background: var(--teal);
  border-radius: 3px;
  transform-origin: left;
  transform: scaleX(0);
  transition: transform 1s cubic-bezier(0.22,1,0.36,1);
  display: flex;
  align-items: center;
}
.bar-val { font-family: 'IBM Plex Mono', monospace; font-size: 0.75rem; color: var(--teal); font-weight: 500; }

/* ── TIME PATTERNS ── */
.time-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 1px;
  background: var(--border);
  border: 1px solid var(--border);
  border-radius: 6px;
  overflow: hidden;
  margin-bottom: 2rem;
}
.time-card {
  background: var(--surface);
  padding: 1.4rem 1.5rem;
  cursor: pointer;
  transition: background 0.2s;
  position: relative;
}
.time-card:hover { background: var(--teal-light); }
.time-card.open { background: var(--teal); color: #fff; }
.time-card h4 { font-size: 0.82rem; font-weight: 600; margin-bottom: 0.3rem; }
.time-card .peak {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 1.1rem;
  font-weight: 500;
  color: var(--teal);
  margin-bottom: 0.3rem;
}
.time-card.open .peak { color: #a7f3d0; }
.time-card .sub { font-size: 0.75rem; color: var(--ink-muted); }
.time-card.open .sub { color: rgba(255,255,255,0.7); }
.time-detail {
  overflow: hidden;
  max-height: 0;
  transition: max-height 0.4s ease;
  font-size: 0.82rem;
  line-height: 1.7;
  color: rgba(255,255,255,0.85);
}
.time-card.open .time-detail { max-height: 200px; margin-top: 0.8rem; }

/* ── REGION TABLE ── */
.region-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.82rem;
}
.region-table th {
  background: var(--teal);
  color: #fff;
  padding: 0.7rem 1rem;
  text-align: left;
  font-weight: 500;
  font-size: 0.75rem;
  letter-spacing: 0.04em;
}
.region-table td {
  padding: 0.7rem 1rem;
  border-bottom: 1px solid var(--border);
  cursor: pointer;
  transition: background 0.15s;
}
.region-table tr:hover td { background: var(--teal-light); }
.region-table tr.expanded td { background: var(--teal-light); }
.expand-row td {
  background: var(--teal-light) !important;
  padding: 0 1rem;
  cursor: default;
}
.expand-content {
  overflow: hidden;
  max-height: 0;
  transition: max-height 0.4s ease, padding 0.3s;
  font-size: 0.82rem;
  color: var(--ink-soft);
  line-height: 1.8;
}
.expand-content.open { max-height: 200px; padding: 0.8rem 0; }
.rate-pill {
  display: inline-block;
  padding: 0.15rem 0.5rem;
  border-radius: 99px;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.72rem;
  font-weight: 500;
}
.rate-high { background: #fee2e2; color: #991b1b; }
.rate-mid  { background: #fef3c7; color: #92400e; }
.rate-low  { background: #d1fae5; color: #065f46; }

/* ── FINDINGS ACCORDION ── */
.finding-item {
  border: 1px solid var(--border);
  border-radius: 6px;
  margin-bottom: 0.8rem;
  overflow: hidden;
  background: var(--surface);
  box-shadow: var(--shadow);
  transition: box-shadow 0.3s;
}
.finding-item:hover { box-shadow: 0 2px 12px rgba(0,0,0,0.1); }
.finding-header {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1.2rem 1.5rem;
  cursor: pointer;
  user-select: none;
}
.finding-num {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.72rem;
  font-weight: 500;
  color: var(--surface);
  background: var(--teal);
  width: 26px;
  height: 26px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.finding-title { font-size: 0.92rem; font-weight: 600; flex: 1; }
.finding-arrow {
  font-size: 0.7rem;
  color: var(--ink-muted);
  transition: transform 0.3s;
}
.finding-item.open .finding-arrow { transform: rotate(90deg); }
.finding-body {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.45s cubic-bezier(0.22,1,0.36,1);
  font-size: 0.87rem;
  color: var(--ink-soft);
  line-height: 1.85;
}
.finding-item.open .finding-body { max-height: 400px; }
.finding-body-inner { padding: 0 1.5rem 1.5rem 3.6rem; }
.finding-highlight {
  background: var(--teal-light);
  border-left: 3px solid var(--teal);
  padding: 0.6rem 1rem;
  font-size: 0.82rem;
  color: var(--teal);
  border-radius: 0 4px 4px 0;
  margin-top: 0.8rem;
  font-weight: 500;
}

/* ── ECON CARDS ── */
.econ-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
  margin-bottom: 2rem;
}
.econ-card {
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 1.5rem;
  background: var(--surface);
  box-shadow: var(--shadow);
  cursor: pointer;
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}
.econ-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: var(--teal);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.3s;
}
.econ-card:hover::before, .econ-card.active::before { transform: scaleX(1); }
.econ-card:hover { transform: translateY(-2px); box-shadow: 0 4px 20px rgba(0,0,0,0.1); }
.econ-card.active { background: var(--teal-light); border-color: var(--teal); }
.econ-indicator {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.65rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--teal);
  margin-bottom: 0.5rem;
}
.econ-title { font-weight: 600; font-size: 0.9rem; margin-bottom: 0.5rem; }
.econ-r { font-family: 'IBM Plex Mono', monospace; font-size: 1.4rem; font-weight: 500; color: var(--teal); }
.econ-desc { font-size: 0.78rem; color: var(--ink-muted); margin-top: 0.3rem; }

.econ-detail-box {
  background: var(--surface);
  border: 1px solid var(--teal);
  border-radius: 6px;
  padding: 1.5rem 2rem;
  font-size: 0.87rem;
  color: var(--ink-soft);
  line-height: 1.85;
  display: none;
  animation: fadeIn 0.3s;
  box-shadow: var(--shadow);
}
.econ-detail-box.visible { display: block; }

/* ── CAVEAT BOX ── */
.caveat-box {
  background: var(--amber-light);
  border: 1px solid #fcd34d;
  border-radius: 6px;
  padding: 1.2rem 1.5rem;
  font-size: 0.85rem;
  color: #78350f;
  line-height: 1.8;
  margin-top: 1rem;
}
.caveat-box h4 { font-weight: 600; margin-bottom: 0.4rem; color: var(--amber); }

/* ── CRISIS FOOTER ── */
.crisis-footer {
  background: var(--rose-light);
  border-top: 2px solid #fecdd3;
  padding: 2.5rem 3rem;
  text-align: center;
}
.crisis-footer h3 {
  font-family: 'Noto Serif SC', serif;
  font-size: 1rem;
  color: var(--rose);
  margin-bottom: 0.8rem;
}
.crisis-footer p { font-size: 0.85rem; color: #6b1c2c; line-height: 1.8; }
.crisis-footer .hotline {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 1.2rem;
  font-weight: 500;
  color: var(--rose);
  display: block;
  margin: 0.8rem 0;
}

/* ── FOOTER ── */
footer {
  background: var(--ink);
  color: rgba(255,255,255,0.45);
  padding: 2rem 3rem;
  text-align: center;
  font-size: 0.72rem;
  line-height: 2;
}

/* ── REVEAL ── */
.reveal { opacity: 0; transform: translateY(18px); transition: opacity 0.6s, transform 0.6s cubic-bezier(0.22,1,0.36,1); }
.reveal.visible { opacity: 1; transform: none; }

@media (max-width: 700px) {
  .stats-strip { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
  .stat-item + .stat-item { border: none; }
  .econ-grid { grid-template-columns: 1fr; }
  nav { padding: 0 1rem; }
  section { padding: 3rem 1.5rem; }
  .hero { padding: 3rem 1.5rem; }
}
</style>
</head>
