    ['K1','K2','K3','K4','K5'].forEach(k => {
      const pct = (d[k] / max * 100).toFixed(1);
      const colors = { K1:'#2d6a6a', K2:'#3d8b8b', K3:'#f59e0b', K4:'#ef4444', K5:'#991b1b' };
      el.innerHTML += `
        <div class="bar-row">
          <label style="font-size:0.7rem">${d.stage.split(' ')[0]} ${k}</label>
          <div class="bar-track" style="background:#f0f0f0">
            <div class="bar-fill" style="width:${pct}%;background:${colors[k]}" data-w="${pct}"></div>
          </div>
          <span class="bar-val" style="color:${colors[k]}">${d[k].toLocaleString()}</span>
        </div>`;
    });
  });
})();

// ── INTERACTIONS ────────────────────────────────

function toggleTime(card) {
  const wasOpen = card.classList.contains('open');
  document.querySelectorAll('.time-card').forEach(c => c.classList.remove('open'));
  if (!wasOpen) card.classList.add('open');
}

function toggleRegion(row, idx) {
  const content = document.getElementById('expand-content-' + idx);
  const isOpen = content.classList.contains('open');
  document.querySelectorAll('.expand-content').forEach(c => c.classList.remove('open'));
  document.querySelectorAll('.region-table tr').forEach(r => r.classList.remove('expanded'));
  if (!isOpen) {
    content.classList.add('open');
    row.classList.add('expanded');
  }
}

function switchTab(btn, panelId) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById(panelId).classList.add('active');
  // trigger bars
  setTimeout(triggerBars, 100);
}

function showEcon(card, key) {
  document.querySelectorAll('.econ-card').forEach(c => c.classList.remove('active'));
  card.classList.add('active');
  const box = document.getElementById('econDetail');
  box.innerHTML = econDetails[key];
  box.classList.add('visible');
}

function toggleFinding(item) {
  const wasOpen = item.classList.contains('open');
  document.querySelectorAll('.finding-item').forEach(f => f.classList.remove('open'));
  if (!wasOpen) item.classList.add('open');
}

// ── SCROLL REVEAL ────────────────────────────────

const observer = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.classList.add('visible');
      triggerBars();
    }
  });
}, { threshold: 0.1 });

document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

// counter observer
const counterObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      animateCount(document.getElementById('cnt1'), 12276);
      animateCount(document.getElementById('cnt2'), 2851);
      counterObs.disconnect();
    }
  });
}, { threshold: 0.5 });
counterObs.observe(document.querySelector('.stats-strip'));

// bars animation
let barsTriggered = false;
function triggerBars() {
  document.querySelectorAll('.bar-fill[data-w]').forEach(el => {
    const w = el.dataset.w;
    requestAnimationFrame(() => { el.style.transform = `scaleX(${parseFloat(w)/100})`; });
  });
}
const barObserver = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting && !barsTriggered) { barsTriggered = true; triggerBars(); } });
}, { threshold: 0.2 });
document.getElementById('provinceBars') && barObserver.observe(document.getElementById('provinceBars'));
</script>
