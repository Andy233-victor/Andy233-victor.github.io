</div>

<!-- NAV -->
<nav>
  <div class="nav-logo">中国自杀死亡时空研究</div>
  <a href="#overview">研究概述</a>
  <a href="#temporal">时间规律</a>
  <a href="#spatial">空间分布</a>
  <a href="#evolution">时空演化</a>
